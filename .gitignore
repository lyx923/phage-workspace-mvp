# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables (contains API keys, DB passwords)
.env
.env.local
.env.*.local

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db

# Logs and databases
*.log
*.db
*.sqlite
*.sqlite3

# Neo4j database dump (can be large, handled separately)
*.dump
neo4j-data/

# Output directories (optional - if not versioned)
/outputs/
# but if you want to keep reports, can comment out outputs/ and selectively add

# Temporary files
tmp/
temp/
*.tmp

# Package manager lock files (optional)
# pipenv: Pipfile.lock
# poetry: poetry.lock

# DeepSeek cache (if any)
.cache/